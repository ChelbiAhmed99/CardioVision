# Backend Environment Variables
PORT=3000
JWT_SECRET=your_jwt_secret_here
NODE_ENV=production
CLIENT_URL=https://cardiovision-production.up.railway.app
FLASK_API_URL=http://flask-ai.railway.internal:8080
FLASK_ENV=development

# AI Service Variables (Flask)
# Usually managed via Docker, but can be set for local dev
FLASK_ENV=development
DATA_PATH=./input
OUTPUT_PATH=./output
EF_MODEL_PATH=models/r2plus1d_18_32_2_pretrained.pt
SEG_MODEL_PATH=models/deeplabv3_resnet50_random.pt
EF_MODEL_URL=https://github.com/ChelbiAhmed99/CardioVision/releases/download/v1.0/r2plus1d_18_32_2_pretrained.pt
SEG_MODEL_URL=https://github.com/ChelbiAhmed99/CardioVision/releases/download/v1.0/deeplabv3_resnet50_random.pt
