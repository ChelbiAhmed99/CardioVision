{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://cardiovision-backend.onrender.com/api/:path*"
        },
        {
            "source": "/uploads/:path*",
            "destination": "https://cardiovision-backend.onrender.com/uploads/:path*"
        },
        {
            "source": "/(?!api|uploads|static).*|/",
            "destination": "/index.html"
        }
    ]
}